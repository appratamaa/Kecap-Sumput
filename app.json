{
  "expo": {
    "name": "Kecap Sumput",
    "slug": "kecap-sumput",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.kecapsumput"
    },
    "android": {
      "package": "com.anonymous.kecapsumput",
      "jsEngine": "jsc",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/logo.png"
      }
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Izinkan Kecap Sumput mengakses kamera untuk mengambil foto profil.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f2bf5fd0-ba09-4e34-839c-d84e355a4fbf"
      }
    }
  }
}